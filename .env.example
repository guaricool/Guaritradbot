# Binane API Keys (Producción)
BINANCE_API_KEY="tu_api_key_aqui"
BINANCE_API_SECRET="tu_api_secret_aqui"

# Alpaca API Keys (Sprint 36 — equities/ETFs).
# Get them at https://app.alpaca.markets → Login → API Keys (paper).
# Required for the bot to route SPY/QQQ/GLD/USO orders.
# If left blank, the bot gracefully falls back to crypto-only mode.
ALPACA_API_KEY=""
ALPACA_SECRET_KEY=""

# Telegram Bot (Para Notificaciones)
# 1. Crea un bot hablando con @BotFather en Telegram para obtener el TOKEN
# 2. Habla con @userinfobot para obtener tu CHAT_ID
TELEGRAM_BOT_TOKEN="tu_telegram_bot_token"
TELEGRAM_CHAT_ID="tu_chat_id"
