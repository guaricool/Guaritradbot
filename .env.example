# Binane API Keys (Producción)
BINANCE_API_KEY="tu_api_key_aqui"
BINANCE_API_SECRET="tu_api_secret_aqui"

# Alpaca API Keys (Sprint 36 — equities/ETFs).
# Get them at https://app.alpaca.markets → Login → API Keys (paper).
# Required for the bot to route SPY/QQQ/GLD/USO orders.
# If left blank, the bot gracefully falls back to crypto-only mode.
ALPACA_API_KEY=""
ALPACA_SECRET_KEY=""

# Telegram Bot (Para Notificaciones)
# 1. Crea un bot hablando con @BotFather en Telegram para obtener el TOKEN
# 2. Habla con @userinfobot para obtener tu CHAT_ID
TELEGRAM_BOT_TOKEN="tu_telegram_bot_token"
TELEGRAM_CHAT_ID="tu_chat_id"

# Dashboard password (Sprint 45 — H8 fix).
# The Streamlit dashboard had ZERO authentication and is directly
# exposed on port 8501 (docker-compose maps it straight to the host).
# Set a real password here — the dashboard refuses to render
# anything (fails CLOSED) until this is set.
DASHBOARD_PASSWORD=""

# Sprint 46N (audit A9) — dashboard API hardening.
#
# DASHBOARD_CORS_ORIGINS: REQUIRED for the browser dashboard to load
# data. This used to default to "*" (any website could call the API);
# it now fails CLOSED with no origins allowed until you set this to
# the dashboard's actual public URL (comma-separated if more than
# one). Per this repo's docker-compose.yml, that's currently:
DASHBOARD_CORS_ORIGINS="http://13.140.181.29:3050"

# DASHBOARD_TOKEN_SECRET: OPTIONAL. Previously, tokens were signed
# using DASHBOARD_PASSWORD itself as the HMAC key — if the password is
# weak, someone who saw one issued token could brute-force the
# password offline. Set this to a long random string (e.g.
# `openssl rand -hex 32`) for an operator-controlled signing secret. If
# left unset, the bot auto-generates and persists one at
# audit/token_secret.key on first use (inside the bot_audit volume, so
# it survives redeploys) — no action needed, but setting this
# explicitly (e.g. via a Coolify secret) is a bit stronger.
DASHBOARD_TOKEN_SECRET=""

# Optional tuning for the login brute-force throttle and the
# /api/restart cooldown (audit A9/A10). Defaults shown; usually no
# need to change these.
# DASHBOARD_LOGIN_MAX_ATTEMPTS=5
# DASHBOARD_LOGIN_WINDOW_SECONDS=900
# DASHBOARD_LOGIN_LOCKOUT_SECONDS=900
# DASHBOARD_RESTART_COOLDOWN_SECONDS=60

# Coolify Deploy Token (Sprint 43 — C1 fix).
# Used by deploy.sh and .deploy.php to trigger manual deploys via Coolify
# REST API. NEVER commit this value to the repo. Keep it in:
#   - The VPS shell environment (export COOLIFY_TOKEN=...) for manual deploys
#   - The bot's Coolify Environment tab (NOT in this file) if you want it
#     accessible to the bot container
COOLIFY_TOKEN=""
