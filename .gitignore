# ─────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/

# ─────────────────────────────────────────────────────────────────
# Runtime state (regenerated on every bot run)
# (Anchored to repo root so we don't accidentally ignore
# `dashboard/src/app/(app)/audit/page.tsx` etc.)
# ─────────────────────────────────────────────────────────────────
/latest_state.json
/audit/
/logs/

# ─────────────────────────────────────────────────────────────────
# data_store/ — CSV files ARE tracked (needed for reproducible backtests)
# Future state/cache files are excluded:
# ─────────────────────────────────────────────────────────────────
/data_store/*.json
/data_store/*.db
/data_store/*.sqlite
/data_store/*.pkl
/data_store/*.parquet

# ─────────────────────────────────────────────────────────────────
# Secrets — NEVER track
# ─────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────────────────────────
# Virtual environments
# ─────────────────────────────────────────────────────────────────
venv/
.venv/
env/

# ─────────────────────────────────────────────────────────────────
# External reference repos (cloned for inspiration, NOT part of this project)
# ─────────────────────────────────────────────────────────────────
external_repos/

# ─────────────────────────────────────────────────────────────────
# Project memory notes (private to author)
# ─────────────────────────────────────────────────────────────────
MEMORY.md

# ─────────────────────────────────────────────────────────────────
# Analysis artifacts (screenshots, mockups — local only)
# ─────────────────────────────────────────────────────────────────
.analysis/

# ─────────────────────────────────────────────────────────────────
# Streamlit secrets (per-deployment, not committed)
# ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ─────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────
*.log

# ─────────────────────────────────────────────────────────────────
# OS files
# ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────────
# IDE
# ─────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ─────────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────────
*.swp
*.tmp
*.bak